## Блок 2. VoxelCompressorNet — архитектура нейросети

Это небольшая сеть, работающая целиком на GPU. Её задача — принять кластер вокселей и выдать компактный `VoxelAsset`, который визуально и физически неотличим от оригинала при наблюдении с расстояния.

```python
import torch
import torch.nn as nn

class VoxelCompressorNet(nn.Module):
    """
    Вход: кластер 4×4×4 = 64 вокселя, каждый — вектор 32 свойства
    Выход: VoxelAsset — компактное описание + список триггеров + confidence
    
    Параметры: ~2M — работает на GPU за ~0.3мс на кластер
    """
    def __init__(self):
        super().__init__()

        # Энкодер: воспринимает пространственную структуру кластера
        self.spatial_encoder = nn.Sequential(
            nn.Conv3d(32, 64, kernel_size=2, stride=1),   # 4^3 → 3^3
            nn.ReLU(),
            nn.Conv3d(64, 128, kernel_size=2, stride=1),  # 3^3 → 2^3
            nn.ReLU(),
            nn.Flatten(),                                   # 128 * 8 = 1024
        )

        # Латентное пространство — "суть" кластера
        self.latent = nn.Sequential(
            nn.Linear(1024, 256),
            nn.ReLU(),
            nn.Linear(256, 128),
        )

        # Декодер-1: оптимизированный меш (вершины опорного полигона)
        self.mesh_decoder = nn.Sequential(
            nn.Linear(128, 64),
            nn.ReLU(),
            nn.Linear(64, 24),   # 12 вершин × 2 координаты (2D) или ×3 (3D)
        )

        # Декодер-2: физический прокси (упрощённая физика)
        self.physics_decoder = nn.Sequential(
            nn.Linear(128, 64),
            nn.ReLU(),
            nn.Linear(64, 16),   # hardness, elasticity, mass, friction, ...
        )

        # Декодер-3: химический профиль (агрегированный)
        self.chem_decoder = nn.Sequential(
            nn.Linear(128, 32),
            nn.ReLU(),
            nn.Linear(32, 12),   # dominant + 8 компонентов + T + P + phase
        )

        # Декодер-4: список триггеров инвалидации
        self.trigger_decoder = nn.Sequential(
            nn.Linear(128, 64),
            nn.ReLU(),
            nn.Linear(64, 20),   # 20 типов триггеров, sigmoid → вероятность
            nn.Sigmoid(),
        )

        # Оценщик уверенности — насколько сеть уверена в результате
        self.confidence_head = nn.Sequential(
            nn.Linear(128, 32),
            nn.ReLU(),
            nn.Linear(32, 1),
            nn.Sigmoid(),        # 0 = полная аномалия, 1 = уверен
        )

    def forward(self, voxel_cluster):
        # voxel_cluster: [batch, 32_props, 4, 4, 4]
        spatial = self.spatial_encoder(voxel_cluster)
        z = self.latent(spatial)

        mesh       = self.mesh_decoder(z)
        physics    = self.physics_decoder(z)
        chemistry  = self.chem_decoder(z)
        triggers   = self.trigger_decoder(z)   # вероятность каждого триггера
        confidence = self.confidence_head(z)

        return {
            'mesh':       mesh,
            'physics':    physics,
            'chemistry':  chemistry,
            'triggers':   triggers,
            'confidence': confidence,
        }
```

### Как обучать эту сеть

Датасет генерируется самой симуляцией: прогоняем полную симуляцию → записываем кластеры + их «правильное» сжатое представление (вычисленное аналитически). Это называется self-supervised learning — симуляция сама себе учитель.

```python
def generate_training_sample(cluster: list[PolyVoxel]):
    """
    Создаём обучающую пару: кластер → правильный VoxelAsset
    Вызывается в фоне во время работы симуляции
    """
    # Аналитически вычисляем "правильный" ответ
    correct_mesh     = analytic_merge_mesh(cluster)     # точный меш
    correct_physics  = analytic_merge_physics(cluster)  # точная физика
    correct_chem     = analytic_merge_chemistry(cluster)
    correct_triggers = compute_correct_triggers(cluster)

    return {
        'input':  voxels_to_tensor(cluster),
        'target': {
            'mesh':      correct_mesh,
            'physics':   correct_physics,
            'chemistry': correct_chem,
            'triggers':  correct_triggers,
            'confidence': 1.0,  # аналитические данные = полная уверенность
        }
    }

# Loss функция — взвешенная сумма нескольких задач
def total_loss(pred, target):
    mesh_loss      = F.mse_loss(pred['mesh'],      target['mesh'])
    physics_loss   = F.mse_loss(pred['physics'],   target['physics'])
    chem_loss      = F.mse_loss(pred['chemistry'], target['chemistry'])
    # Триггеры — бинарная классификация
    trigger_loss   = F.binary_cross_entropy(pred['triggers'], target['triggers'])
    # Confidence обучаем отдельно: насколько pred['mesh'] близок к target['mesh']
    actual_error   = (pred['mesh'] - target['mesh']).abs().mean()
    conf_target    = torch.exp(-actual_error * 5)  # чем меньше ошибка — тем выше уверенность
    conf_loss      = F.mse_loss(pred['confidence'], conf_target)

    return (mesh_loss * 2.0 +    # меш важнее всего
            physics_loss * 1.5 +
            chem_loss * 1.0 +
            trigger_loss * 1.0 +
            conf_loss * 0.5)
```

