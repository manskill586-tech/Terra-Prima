## Блок 3. Система инвалидации — когда VoxelAsset перезаписывается

Каждый `VoxelAsset` хранит список условий, при которых он становится «просроченным» и должен быть пересчитан. Это аналог cache invalidation в программировании.

```cpp
// Все типы триггеров — для живого И неживого
enum class InvalidationTrigger : uint8_t {
    // === МЕХАНИЧЕСКИЕ (живое и неживое) ===
    STRESS_YIELD,          // напряжение превысило предел текучести → деформация
    IMPACT_FRACTURE,       // удар с энергией выше порога → трещина, перелом
    SHEAR_CUT,             // срезающая сила → порез, разрыв
    FRICTION_WEAR,         // трение → износ поверхности
    COMPRESSION_COLLAPSE,  // сжатие → смятие (для пористых структур)

    // === ТЕРМИЧЕСКИЕ ===
    PHASE_TRANSITION,      // изменение фазы (плавление, испарение, замерзание)
    THERMAL_CRACK,         // тепловые трещины при резком перепаде T
    COMBUSTION,            // горение → химический состав меняется

    // === ХИМИЧЕСКИЕ ===
    CORROSION,             // окисление, коррозия поверхности
    DISSOLUTION,           // растворение в жидкости
    NEW_ELEMENT_CONTACT,   // контакт с новым химическим элементом
    REACTION_SPIKE,        // скачок скорости реакции → новые продукты

    // === БИОЛОГИЧЕСКИЕ (только живое) ===
    CELL_DEATH_THRESHOLD,  // гибель > 30% клеток в кластере
    MUSCLE_TEAR,           // разрыв мышечных волокон
    BONE_FRACTURE,         // перелом — отдельный от IMPACT_FRACTURE (медленное давление)
    WOUND_OPEN,            // открытая рана → кровотечение, инфекция-риск
    NECROSIS,              // некроз ткани
    GROWTH,                // рост клеток → объём увеличился → меш устарел

    // === СТРУКТУРНЫЕ (для сооружений, пород) ===
    EROSION_THRESHOLD,     // накопленная эрозия превысила порог
    SEDIMENT_LAYER,        // осадочный слой достиг толщины для нового вокселя
    VOID_COLLAPSE,         // пустота (пещера) обрушилась
};

// Монитор работает параллельно с рендером — опрашивает SIM Core
class InvalidationWatcher {
    struct WatchEntry {
        uint64_t    asset_id;
        AABB        bounds;
        std::vector<InvalidationTrigger> triggers;  // что проверять
        std::vector<float>               thresholds; // пороги для каждого триггера
    };

    std::vector<WatchEntry> entries;

public:
    // Вызывается каждый физический тик (не каждый кадр)
    std::vector<uint64_t> check_invalidations(const SimState& sim) {
        std::vector<uint64_t> invalidated;

        for (auto& e : entries) {
            // Читаем текущее состояние региона из SIM Core
            RegionSnapshot snap = sim.get_region(e.bounds);

            for (int i = 0; i < e.triggers.size(); i++) {
                if (is_triggered(e.triggers[i], snap, e.thresholds[i])) {
                    invalidated.push_back(e.asset_id);
                    break;  // достаточно одного сработавшего триггера
                }
            }
        }
        return invalidated;
    }

private:
    bool is_triggered(InvalidationTrigger t, const RegionSnapshot& s, float threshold) {
        switch (t) {
            case STRESS_YIELD:
                return s.max_stress > threshold;

            case MUSCLE_TEAR:
                // Для живой ткани: скорость повреждения волокон
                return s.fiber_damage_rate > threshold;

            case BONE_FRACTURE:
                // Давление на кость + угол приложения
                return s.compressive_stress > threshold * s.bone_density;

            case WOUND_OPEN:
                // Геометрическая целостность — появился разрыв
                return s.surface_integrity < (1.0f - threshold);

            case PHASE_TRANSITION:
                return s.avg_temperature >= element_data[s.dominant_element].melting_point
                    || s.avg_temperature <= element_data[s.dominant_element].freezing_point;

            case EROSION_THRESHOLD:
                return s.cumulative_erosion > threshold;

            case GROWTH:
                // Биологический рост — объём изменился
                return fabsf(s.current_volume - s.asset_reference_volume) 
                       / s.asset_reference_volume > threshold;

            default:
                return false;
        }
    }
};
```

