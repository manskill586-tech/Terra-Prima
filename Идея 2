## Деформация вокселя — как сжатие меняет форму

Это самая физически честная часть. Вместо анимации мы **пересчитываем вершины полигона** при изменении давления:

```cpp
// Вершины вокселя в локальном пространстве
struct VoxelMesh {
    vec2 vertices[12];  // максимум 12 вершин для нашей системы
    int  vertex_count;
};

// Применяем давление — деформируем форму
VoxelMesh deform_by_pressure(const VoxelMesh& base, const PolyVoxel& v,
                               vec2 pressure_dir, float pressure_magnitude) {
    VoxelMesh result = base;
    
    if (v.phase == GAS) {
        // Газ сжимается равномерно — все вершины приближаются к центру
        float compression = 1.0f - (pressure_magnitude / v.pressure) 
                            * v.compressibility * 0.8f;
        for (int i = 0; i < result.vertex_count; i++) {
            result.vertices[i] *= clamp(compression, 0.1f, 1.5f);
        }
        // Кинетическая энергия = накопленная при сжатии (для симуляции)
        // Она передаётся SIM Core, не рендеру
    }
    
    else if (v.phase == LIQUID) {
        // Жидкость — деформируется В НАПРАВЛЕНИИ давления
        // Объём сохраняется (несжимаемость)
        for (int i = 0; i < result.vertex_count; i++) {
            float proj = dot(normalize(result.vertices[i]), pressure_dir);
            result.vertices[i] += pressure_dir * proj * pressure_magnitude 
                                  * v.viscosity * 0.01f;
        }
        // Нормализуем площадь (сохранение объёма)
        normalize_area(result, base);
    }
    
    else if (v.phase == SOLID) {
        // Твёрдое — деформируется только если превышен предел упругости
        float stress = pressure_magnitude / v.hardness;
        if (stress > YIELD_STRENGTH_THRESHOLD) {
            // Пластическая деформация — вершины смещаются навсегда
            float deform = (stress - YIELD_STRENGTH_THRESHOLD) * 0.01f;
            for (int i = 0; i < result.vertex_count; i++) {
                result.vertices[i] += pressure_dir * deform * (1.0f - v.hardness);
            }
        }
        // Иначе — упругий отклик, форма не меняется (только внутреннее напряжение)
    }
    
    return result;
}
```

