## Блок 4. Эскалация аномалий к Оверлорду

Когда `confidence < 0.75`, компрессор не знает что делать с этим кластером. Он передаёт кейс Оверлорду:

```python
class AnomalyEscalator:
    def __init__(self, klas_core, module_registry):
        self.klas = klas_core
        self.modules = module_registry
        # История решений: если та же аномалия снова → используем кэш
        self.resolution_cache = {}

    def handle(self, asset_id: int, cluster_data: dict, confidence: float):
        # Хешируем кластер для кэша
        cluster_hash = hash_cluster(cluster_data)
        if cluster_hash in self.resolution_cache:
            return self.resolution_cache[cluster_hash]

        # Собираем контекст: что за кластер, что необычного
        context = {
            'cluster': cluster_data,
            'confidence': confidence,
            'anomaly_type': self._detect_anomaly_type(cluster_data),
            'location': cluster_data['world_position'],
        }

        # Оверлорд решает: какой модуль вызвать
        # (может вызвать несколько, если аномалия сложная)
        resolution = self.klas.reason(
            prompt=ANOMALY_PROMPT.format(**context),
            available_modules=['physicist', 'chemist', 'biologist',
                               'geologist', 'climatologist']
        )

        # Например, Оверлорд решает вызвать Химика и Физика
        if 'chemist' in resolution.required_modules:
            chem_analysis = self.modules.call('chemist', context)
            resolution.enrich(chem_analysis)

        if 'physicist' in resolution.required_modules:
            phys_analysis = self.modules.call('physicist', context)
            resolution.enrich(phys_analysis)

        # Результат: новое правило для компрессора
        new_rule = resolution.to_compressor_rule()

        # Добавляем в кэш — не будем спрашивать снова
        self.resolution_cache[cluster_hash] = new_rule

        # Дообучаем компрессор на новом примере
        # (асинхронно, не блокируя игру)
        self._schedule_finetuning(cluster_data, new_rule)

        return new_rule

    def _detect_anomaly_type(self, cluster_data) -> str:
        # Быстрая предварительная классификация без Оверлорда
        c = cluster_data
        if c['psi_field'] > 0.8:          return 'psi_anomaly'
        if c['unknown_element']:           return 'unknown_element'
        if c['reaction_rate'] > 1e6:       return 'exotic_reaction'
        if c['phase'] == 'undefined':      return 'new_phase_state'
        return 'general_uncertainty'
```

