## Блок 1. Октодерево слияния — умный merge вокселей

Принцип прост: если 8 соседних мини-вокселей достаточно похожи по свойствам — они сливаются в один большой. Это повторяется рекурсивно до нужного уровня LOD.

```cpp
// Критерии схожести — все должны выполняться одновременно
bool can_merge(const PolyVoxel& a, const PolyVoxel& b) {
    // 1. Одна и та же фаза (нельзя слить газ с твёрдым)
    if (a.phase != b.phase) return false;

    // 2. Доминирующий элемент совпадает
    if (a.dominant_element != b.dominant_element) return false;

    // 3. Температура близка (допуск зависит от вещества)
    float t_tol = element_data[a.dominant_element].temp_tolerance; // напр. ±50К для камня
    if (fabsf(a.temperature - b.temperature) > t_tol) return false;

    // 4. Давление близко (важно для газов)
    if (a.phase == GAS && fabsf(a.pressure - b.pressure) > 500.0f) return false;

    // 5. Нет активных триггеров инвалидации (поражённый воксель не сливается)
    if (a.damage_flags || b.damage_flags) return false;

    // 6. Состав похож (евклидово расстояние в пространстве состава)
    float composition_dist = 0;
    for (int i = 0; i < 8; i++)
        composition_dist += powf(a.composition[i] - b.composition[i], 2);
    if (sqrtf(composition_dist) > 0.15f) return false;  // порог 15% разницы

    return true;
}

// Сам merge — рекурсивный обход октодерева
struct OctNode {
    PolyVoxel*  leaf_voxel;  // nullptr если это не лист
    OctNode*    children[8]; // nullptr если лист
    int         depth;       // 0 = самый крупный
    AABB        bounds;
    PolyVoxel   merged;      // усреднённые свойства после слияния
};

void try_merge(OctNode* node) {
    if (!node->children[0]) return;  // уже лист

    // Пробуем слить все 8 детей
    for (int i = 1; i < 8; i++) {
        if (!can_merge(node->children[0]->merged, node->children[i]->merged)) {
            return;  // не сливаем — хоть один не подходит
        }
    }

    // Все схожи → усредняем свойства и превращаем в лист
    node->merged = average_voxels(node->children, 8);
    // Освобождаем детей (они больше не нужны в рендере)
    for (int i = 0; i < 8; i++) {
        mark_for_gpu_removal(node->children[i]);
        node->children[i] = nullptr;
    }
    node->leaf_voxel = &node->merged;
}
```

Слияние запускается снизу вверх после каждого физического тика — только для dirty-узлов. Несхожие узлы не трогаются.

