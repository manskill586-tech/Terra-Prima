## Ядро системы — как воксель выбирает свою форму

Каждый воксель — это не квадрат с текстурой. Это **вычисленный полигон**, форма которого является прямым следствием физико-химических свойств вещества внутри. Никаких художников, никаких текстур — только математика.

```cpp
// Структура вокселя — то что хранится в памяти
struct PolyVoxel {
    // Химический состав (агрегированный по чанку)
    uint16_t dominant_element;   // главный элемент (индекс)
    float    composition[8];     // доли топ-8 элементов (сумма = 1.0)
    
    // Физическое состояние
    uint8_t  phase;              // 0=газ, 1=жидкость, 2=твёрдое, 3=плазма
    float    temperature;        // К
    float    pressure;           // Па
    float    density;            // кг/м³
    
    // Механические свойства (выводятся из состава)
    float    hardness;           // 0–1 (0=газ, 1=алмаз)
    float    compressibility;    // 0–1 (0=несжимаем, 1=идеальный газ)
    float    elasticity;         // 0–1 (упругость)
    float    viscosity;          // для жидкостей
    float    porosity;           // 0–1 пористость твёрдых
    
    // Вычисляемые графические свойства (НЕ хранятся, пересчитываются при рендере)
    // polygon_type, vertex_count, scale, color — всё из полей выше
};

// Функция выбора примитива — вызывается один раз при изменении состава
PolygonPrimitive select_primitive(const PolyVoxel& v) {
    
    if (v.phase == GAS) {
        // Газы — треугольники или тетраэдры (в 3D)
        // Большие: много свободного пространства между молекулами
        if (v.compressibility > 0.8) return TRIANGLE_LARGE;
        if (v.compressibility > 0.5) return TRIANGLE_MEDIUM;
        return QUAD;  // почти несжимаемый газ (вырожденный случай)
    }
    
    if (v.phase == LIQUID) {
        // Жидкости — гексагоны (ближайшая упаковка молекул)
        // Вязкие жидкости — пятиугольники (чуть жёстче)
        if (v.viscosity > 0.7) return PENTAGON;
        return HEXAGON;
    }
    
    if (v.phase == SOLID) {
        // Твёрдые — квадраты/прямоугольники, размер зависит от плотности
        // Кристаллы — по симметрии кристаллической решётки
        CrystalSystem cs = get_crystal_system(v.dominant_element);
        switch (cs) {
            case CUBIC:        return SQUARE;
            case HEXAGONAL:    return HEXAGON;
            case TETRAGONAL:   return RECTANGLE;
            case ORTHORHOMBIC: return RECTANGLE_STRETCHED;
            case TRICLINIC:    return IRREGULAR_QUAD;
            case AMORPHOUS:    return VORONOI_CELL; // стекло, аморфные тела
        }
    }
    
    if (v.phase == PLASMA) return TRIANGLE_LARGE; // плазма ведёт себя как газ
    
    return QUAD; // fallback
}
```

