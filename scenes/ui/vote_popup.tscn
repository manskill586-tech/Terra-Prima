[node name="Panel" type="PanelContainer" parent="."]
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -72.0
offset_right = 150.0
offset_bottom = 72.0

[node name="Margin" type="MarginContainer" parent="Panel"]
